# ============================================================================
# OaaS Collections Agent — Environment Variables
# ============================================================================
#
# DEMO MODE: Leave SUPABASE_URL blank to run the dashboard with in-memory
# demo data. No API keys needed — just start the container.
#
# PRODUCTION: Fill in all required keys below.
# ============================================================================

# Anthropic (required for production — message generation + classification)
ANTHROPIC_API_KEY=

# Instantly.ai (required for production — email sending)
INSTANTLY_API_KEY=

# Supabase (required for production — leave blank for demo mode)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Slack notifications (optional)
SLACK_WEBHOOK_URL=

# Codat (Phase 2 — accounting API integration)
CODAT_API_KEY=
CODAT_WEBHOOK_SECRET=

# Vapi (Phase 2 — AI voice calls)
VAPI_API_KEY=

# ElevenLabs (Phase 2 — voice synthesis)
ELEVENLABS_API_KEY=

# Stripe (Phase 3 — billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Application defaults
AGENT_DEFAULT_NAME=Alex
AGENT_DEFAULT_EMAIL=
DEFAULT_CURRENCY=GBP
MAX_DISCOUNT_PERCENT=3
FEE_FLAT_AMOUNT=500
FEE_PERCENTAGE=10
FEE_PERCENTAGE_THRESHOLD=5000
