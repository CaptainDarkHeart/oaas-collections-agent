# OaaS Collections Agent Environment Variables
#
# DEMO MODE: Leave SUPABASE_URL blank to run the dashboard with in memory
# demo data. No API keys needed.
#
# PRODUCTION: Fill in all required keys below.

# Anthropic (required for production, message generation and classification)
ANTHROPIC_API_KEY=

# Supabase (required for production, leave blank for demo mode)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email sending)
RESEND_API_KEY=

# Slack notifications (optional)
SLACK_WEBHOOK_URL=

# Codat (accounting API integration)
CODAT_API_KEY=
CODAT_WEBHOOK_SECRET=

# Vapi (AI voice calls)
VAPI_API_KEY=

# ElevenLabs (voice synthesis)
ELEVENLABS_API_KEY=

# Stripe (debtor payment links and SME fee billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Xero (direct OAuth integration)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# QuickBooks (direct OAuth integration)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_SANDBOX=true

# OAuth settings
OAUTH_REDIRECT_BASE_URL=
# Fernet key for encrypting OAuth tokens. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Instantly.ai (kept for account management)
INSTANTLY_API_KEY=

# Dashboard password (leave blank for open access, JWT auth recommended)
DASHBOARD_PASSWORD=

# Application defaults
AGENT_DEFAULT_NAME=Alex
AGENT_DEFAULT_EMAIL=
DEFAULT_CURRENCY=GBP
MAX_DISCOUNT_PERCENT=3
FEE_FLAT_AMOUNT=500
FEE_PERCENTAGE=10
FEE_PERCENTAGE_THRESHOLD=5000
